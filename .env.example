# G_5.2 Environment Configuration
# Copy this file to .env and fill in your values.
# .env is gitignored. This file is safe to commit.

# ── OpenRouter ──────────────────────────────────────────────────────────────────
# Single API key routes both OpenAI and Anthropic models.
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Model overrides (optional — defaults shown)
# Verify model slugs at: https://openrouter.ai/models
# Azure is a provider on OpenRouter, not part of the model slug. Use
# openai/gpt-5.4 and openai/gpt-5.4-mini rather than Azure/... model IDs.
OPENROUTER_OPENAI_MODEL=openai/gpt-5.4
OPENROUTER_DEFAULT_MODEL=openai/gpt-5.4
OPENROUTER_SECONDARY_MODEL=openai/gpt-5.4-mini
OPENROUTER_ANTHROPIC_MODEL=anthropic/claude-sonnet-4.6
OPENROUTER_GEMINI_MODEL=google/gemini-3.1-pro-preview-20260219
# Comma-separated OpenRouter providers to skip for OpenAI routes.
# Use "none" to allow Azure BYOK and normal OpenRouter routing.
OPENROUTER_IGNORE_PROVIDERS=none

# Eval/default provider selection
# One of: anthropic, openai, openai-secondary, gemini
EVAL_PROVIDER=openai

# ── Supabase ────────────────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# ── Runtime ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info
